{
  "_comment": "SymbolicDag: Distributed word count across 2 nodes.",
  "_comment2": "Submit with: node-agent submit --config agent.toml --dag DAGs/symbolic_dag/word_count.json",
  "_comment3": "The Partitioner auto-generates RemoteSend/RemoteRecv and slot assignments.",
  "shm_path_prefix": "/dev/shm/rdma_wc",
  "log_level": "info",
  "transfer": true,
  "shared_inputs": [
    { "path": "TestData/corpus_large.txt", "source_node": 0 }
  ],
  "nodes": [
    {
      "id": "load_0", "node_id": 0, "deps": [],
      "kind": { "Input": { "path": "TestData/corpus_large.txt", "slot": 0, "prefetch": true } }
    },
    {
      "id": "load_1", "node_id": 1, "deps": [],
      "kind": { "Input": { "path": "TestData/corpus_large.txt", "slot": 0, "prefetch": true } }
    },
    {
      "id": "distribute_0", "node_id": 0, "deps": ["load_0"],
      "kind": { "Func": { "func": "wc_distribute", "arg": 10, "arg2": 10 } }
    },
    {
      "id": "distribute_1", "node_id": 1, "deps": ["load_1"],
      "kind": { "Func": { "func": "wc_distribute", "arg": 10, "arg2": 10 } }
    },
    { "id": "map_0_n0", "node_id": 0, "deps": ["distribute_0"], "kind": { "Func": { "func": "wc_map", "arg": 10, "arg2": 110 } } },
    { "id": "map_1_n0", "node_id": 0, "deps": ["distribute_0"], "kind": { "Func": { "func": "wc_map", "arg": 11, "arg2": 111 } } },
    { "id": "map_2_n0", "node_id": 0, "deps": ["distribute_0"], "kind": { "Func": { "func": "wc_map", "arg": 12, "arg2": 112 } } },
    { "id": "map_3_n0", "node_id": 0, "deps": ["distribute_0"], "kind": { "Func": { "func": "wc_map", "arg": 13, "arg2": 113 } } },
    { "id": "map_4_n0", "node_id": 0, "deps": ["distribute_0"], "kind": { "Func": { "func": "wc_map", "arg": 14, "arg2": 114 } } },
    { "id": "map_5_n0", "node_id": 0, "deps": ["distribute_0"], "kind": { "Func": { "func": "wc_map", "arg": 15, "arg2": 115 } } },
    { "id": "map_6_n0", "node_id": 0, "deps": ["distribute_0"], "kind": { "Func": { "func": "wc_map", "arg": 16, "arg2": 116 } } },
    { "id": "map_7_n0", "node_id": 0, "deps": ["distribute_0"], "kind": { "Func": { "func": "wc_map", "arg": 17, "arg2": 117 } } },
    { "id": "map_8_n0", "node_id": 0, "deps": ["distribute_0"], "kind": { "Func": { "func": "wc_map", "arg": 18, "arg2": 118 } } },
    { "id": "map_9_n0", "node_id": 0, "deps": ["distribute_0"], "kind": { "Func": { "func": "wc_map", "arg": 19, "arg2": 119 } } },
    { "id": "map_0_n1", "node_id": 1, "deps": ["distribute_1"], "kind": { "Func": { "func": "wc_map", "arg": 10, "arg2": 110 } } },
    { "id": "map_1_n1", "node_id": 1, "deps": ["distribute_1"], "kind": { "Func": { "func": "wc_map", "arg": 11, "arg2": 111 } } },
    { "id": "map_2_n1", "node_id": 1, "deps": ["distribute_1"], "kind": { "Func": { "func": "wc_map", "arg": 12, "arg2": 112 } } },
    { "id": "map_3_n1", "node_id": 1, "deps": ["distribute_1"], "kind": { "Func": { "func": "wc_map", "arg": 13, "arg2": 113 } } },
    { "id": "map_4_n1", "node_id": 1, "deps": ["distribute_1"], "kind": { "Func": { "func": "wc_map", "arg": 14, "arg2": 114 } } },
    { "id": "map_5_n1", "node_id": 1, "deps": ["distribute_1"], "kind": { "Func": { "func": "wc_map", "arg": 15, "arg2": 115 } } },
    { "id": "map_6_n1", "node_id": 1, "deps": ["distribute_1"], "kind": { "Func": { "func": "wc_map", "arg": 16, "arg2": 116 } } },
    { "id": "map_7_n1", "node_id": 1, "deps": ["distribute_1"], "kind": { "Func": { "func": "wc_map", "arg": 17, "arg2": 117 } } },
    { "id": "map_8_n1", "node_id": 1, "deps": ["distribute_1"], "kind": { "Func": { "func": "wc_map", "arg": 18, "arg2": 118 } } },
    { "id": "map_9_n1", "node_id": 1, "deps": ["distribute_1"], "kind": { "Func": { "func": "wc_map", "arg": 19, "arg2": 119 } } },
    {
      "id": "aggregate", "node_id": 0,
      "deps": ["map_0_n0","map_1_n0","map_2_n0","map_3_n0","map_4_n0","map_5_n0","map_6_n0","map_7_n0","map_8_n0","map_9_n0"],
      "kind": { "Aggregate": { "upstream": [110,111,112,113,114,115,116,117,118,119], "downstream": 200 } }
    },
    {
      "id": "aggregate_local", "node_id": 1,
      "deps": ["map_0_n1","map_1_n1","map_2_n1","map_3_n1","map_4_n1","map_5_n1","map_6_n1","map_7_n1","map_8_n1","map_9_n1"],
      "kind": { "Aggregate": { "upstream": [110,111,112,113,114,115,116,117,118,119], "downstream": 200 } }
    },
    {
      "id": "aggregate_global", "node_id": 1,
      "deps": ["aggregate", "aggregate_local"],
      "kind": { "Aggregate": { "upstream_nodes": ["aggregate", "aggregate_local"], "downstream": 300 } }
    },
    {
      "id": "reduce", "node_id": 1, "deps": ["aggregate_global"],
      "kind": { "Func": { "func": "wc_reduce", "arg": 300 } }
    },
    {
      "id": "save", "node_id": 1, "deps": ["reduce"],
      "kind": { "Output": { "path": "TestOutput/rdma_word_count_result.txt" } }
    }
  ]
}
