{
  "_comment": [
    "SymbolicDag: FINRA audit with partitioner-managed placement.",
    "",
    "placement:'all' nodes run one copy per machine:",
    "  load_trades, fetch_private, fetch_public, aggregate_inputs",
    "  rule_0..7, aggregate_rules",
    "",
    "shared_inputs is auto-derived from the 'load_trades' Input node.",
    "",
    "Auto-placed nodes: aggregate_global, merge, save (Pack → colocate on node 0).",
    "",
    "Slot conventions (preserved from ClusterDag for WASM/Python compatibility):",
    "  fetch_private: reads slot 0 (trades), writes slot 5",
    "  fetch_public:  wasm_arg=0 overrides arg in WASM mode; Python uses arg=6",
    "  aggregate_inputs: upstream=[5,6], downstream=200",
    "  rule_i: WASM uses wasm_arg=i (rule index); Python uses arg=200 (input slot)",
    "          output slots 10..17 are written by the WASM function internally",
    "  aggregate_rules: upstream=[10..17], downstream=300"
  ],
  "shm_path_prefix": "/dev/shm/rdma_finra_ap",
  "log_level": "info",
  "transfer": true,
  "total_nodes": 2,
  "placement_policy": "pack",
  "nodes": [
    {
      "id": "load_trades", "placement": "all", "deps": [],
      "kind": { "Input": { "path": "TestData/trades.csv", "prefetch": true } }
    },
    {
      "id": "fetch_private", "placement": "all", "deps": ["load_trades"],
      "kind": { "Func": { "func": "finra_fetch_private", "arg": 0, "arg2": 5 } }
    },
    {
      "id": "fetch_public", "placement": "all", "deps": [],
      "kind": { "Func": { "func": "finra_fetch_public", "arg": 6, "wasm_arg": 0 } }
    },
    {
      "id": "aggregate_inputs", "placement": "all", "deps": ["fetch_private", "fetch_public"],
      "kind": { "Aggregate": { "upstream": [5, 6], "downstream": 200 } }
    },
    { "id": "rule_0", "placement": "all", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 0, "wasm_arg": 0 } } },
    { "id": "rule_1", "placement": "all", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 1, "wasm_arg": 1 } } },
    { "id": "rule_2", "placement": "all", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 2, "wasm_arg": 2 } } },
    { "id": "rule_3", "placement": "all", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 3, "wasm_arg": 3 } } },
    { "id": "rule_4", "placement": "all", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 4, "wasm_arg": 4 } } },
    { "id": "rule_5", "placement": "all", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 5, "wasm_arg": 5 } } },
    { "id": "rule_6", "placement": "all", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 6, "wasm_arg": 6 } } },
    { "id": "rule_7", "placement": "all", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 7, "wasm_arg": 7 } } },
    {
      "id": "aggregate_rules", "placement": "all",
      "deps": ["rule_0","rule_1","rule_2","rule_3","rule_4","rule_5","rule_6","rule_7"],
      "kind": { "Aggregate": { "upstream": [10, 11, 12, 13, 14, 15, 16, 17], "downstream": 300 } }
    },
    {
      "id": "aggregate_global", "deps": ["aggregate_rules"],
      "kind": { "Aggregate": {} }
    },
    {
      "id": "merge", "deps": ["aggregate_global"],
      "kind": { "Func": { "func": "finra_merge_results" } }
    },
    {
      "id": "save", "deps": ["merge"],
      "kind": { "Output": { "path": "TestOutput/finra_ap_result.txt" } }
    }
  ]
}
