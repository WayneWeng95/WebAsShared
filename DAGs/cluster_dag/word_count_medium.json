{
  "_comment": "ClusterDag: Distributed word count across 2 nodes via RDMA (medium, ~10 MiB corpus).",
  "_comment2": "Node 0 computes local aggregate and sends to node 1.",
  "_comment3": "Node 1 computes local aggregate, receives node 0's, merges, and reduces.",
  "_comment4": "Uses unified Func nodes. Submit with --python for Python execution.",
  "shm_path_prefix": "/dev/shm/rdma_wc_medium",
  "log_level": "info",
  "transfer": true,
  "node_dags": {
    "0": [
      {
        "id": "load", "deps": [],
        "kind": { "Input": { "path": "Executor/data/corpus_medium.txt", "slot": 0, "prefetch": true } }
      },
      {
        "id": "distribute", "deps": ["load"],
        "kind": { "Func": { "func": "wc_distribute", "arg": 10, "arg2": 10 } }
      },
      { "id": "map_0", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 10, "arg2": 110 } } },
      { "id": "map_1", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 11, "arg2": 111 } } },
      { "id": "map_2", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 12, "arg2": 112 } } },
      { "id": "map_3", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 13, "arg2": 113 } } },
      { "id": "map_4", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 14, "arg2": 114 } } },
      { "id": "map_5", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 15, "arg2": 115 } } },
      { "id": "map_6", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 16, "arg2": 116 } } },
      { "id": "map_7", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 17, "arg2": 117 } } },
      { "id": "map_8", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 18, "arg2": 118 } } },
      { "id": "map_9", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 19, "arg2": 119 } } },
      {
        "id": "aggregate", "deps": ["map_0","map_1","map_2","map_3","map_4","map_5","map_6","map_7","map_8","map_9"],
        "kind": { "Aggregate": { "upstream": [110,111,112,113,114,115,116,117,118,119], "downstream": 200 } }
      },
      {
        "id": "send", "deps": ["aggregate"],
        "kind": { "RemoteSend": { "slot": 200, "slot_kind": "Stream", "peer": 1 } }
      }
    ],
    "1": [
      {
        "id": "load", "deps": [],
        "kind": { "Input": { "path": "Executor/data/corpus_medium.txt", "slot": 0, "prefetch": true } }
      },
      {
        "id": "distribute", "deps": ["load"],
        "kind": { "Func": { "func": "wc_distribute", "arg": 10, "arg2": 10 } }
      },
      { "id": "map_0", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 10, "arg2": 110 } } },
      { "id": "map_1", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 11, "arg2": 111 } } },
      { "id": "map_2", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 12, "arg2": 112 } } },
      { "id": "map_3", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 13, "arg2": 113 } } },
      { "id": "map_4", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 14, "arg2": 114 } } },
      { "id": "map_5", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 15, "arg2": 115 } } },
      { "id": "map_6", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 16, "arg2": 116 } } },
      { "id": "map_7", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 17, "arg2": 117 } } },
      { "id": "map_8", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 18, "arg2": 118 } } },
      { "id": "map_9", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 19, "arg2": 119 } } },
      {
        "id": "aggregate_local",
        "deps": ["map_0","map_1","map_2","map_3","map_4","map_5","map_6","map_7","map_8","map_9"],
        "kind": { "Aggregate": { "upstream": [110,111,112,113,114,115,116,117,118,119], "downstream": 200 } }
      },
      {
        "id": "recv", "deps": ["distribute"],
        "kind": { "RemoteRecv": { "slot": 201, "slot_kind": "Stream", "peer": 0 } }
      },
      {
        "id": "aggregate_global", "deps": ["aggregate_local", "recv"],
        "kind": { "Aggregate": { "upstream": [200, 201], "downstream": 300 } }
      },
      {
        "id": "reduce", "deps": ["aggregate_global"],
        "kind": { "Func": { "func": "wc_reduce", "arg": 300 } }
      },
      {
        "id": "save", "deps": ["reduce"],
        "kind": { "Output": { "path": "/tmp/rdma_word_count_medium_result.txt" } }
      }
    ]
  }
}
