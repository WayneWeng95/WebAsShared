{
  "_comment": "Image pipeline demo: load PPM -> rotate -> grayscale -> equalize -> blur -> export.",
  "_comment2": "StreamPipeline (software-pipelined, one image per round). Per-round images are fanned to one file each via Output split_records.",
  "shm_path": "/dev/shm/img_pipeline_demo",
  "wasm_path": "Executor/target/wasm32-unknown-unknown/release/guest.wasm",
  "log_level": "info",
  "runs": 1,

  "nodes": [
    {
      "id": "load",
      "deps": [],
      "kind": { "Input": {
        "paths": [
          "TestData/img_gradient.ppm",
          "TestData/img_checkerboard.ppm",
          "TestData/img_rings.ppm"
        ],
        "slot": 10,
        "binary": true
      }}
    },

    {
      "id": "pipeline",
      "deps": ["load"],
      "kind": { "StreamPipeline": {
        "rounds": 3,
        "stages": [
          { "func": "img_load_ppm",  "arg0": 10, "arg1": 20 },
          { "func": "img_rotate",    "arg0": 20, "arg1": 30 },
          { "func": "img_grayscale", "arg0": 30, "arg1": 40 },
          { "func": "img_equalize",  "arg0": 40, "arg1": 50 },
          { "func": "img_blur",      "arg0": 50, "arg1": 60 },
          { "func": "img_export_ppm","arg0": 60, "arg1": 1  }
        ]
      }}
    },

    {
      "id": "save",
      "deps": ["pipeline"],
      "kind": { "Output": {
        "paths": [
          "TestOutput/img_pipeline_out/gradient_processed.pgm",
          "TestOutput/img_pipeline_out/checkerboard_processed.pgm",
          "TestOutput/img_pipeline_out/rings_processed.pgm"
        ],
        "slot": 1,
        "split_records": true
      }}
    },

    {
      "id": "free",
      "deps": ["save"],
      "kind": { "FreeSlots": { "stream": [20, 30, 40, 50, 60], "io": [1] } }
    }
  ]
}
