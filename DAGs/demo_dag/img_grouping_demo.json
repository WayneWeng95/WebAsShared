{
  "shm_path": "/dev/shm/img_grouping_demo",
  "wasm_path": "Executor/target/wasm32-unknown-unknown/release/guest.wasm",
  "log_level": "info",
  "mode": "reset",
  "runs": 3,

  "_comment": [
    "WasmGrouping demo — mirrors py_img_grouping_demo.json in structure.",
    "",
    "Input loads one PPM file per run (cycle: true), so run 0 → gradient,",
    "run 1 → checkerboard, run 2 → rings.  A single WasmGrouping node runs",
    "the full 6-stage chain on that one image, writing the result to I/O slot 1.",
    "Output cycles through three destination paths in lock-step with the input.",
    "FreeSlots frees and resets all cursors so the next run starts clean.",
    "",
    "This contrasts with StreamPipeline (img_pipeline_demo.json), which overlaps",
    "stages across rounds — here each image completes the full chain before the next begins."
  ],

  "nodes": [
    {
      "id": "load",
      "deps": [],
      "kind": { "Input": {
        "paths": [
          "Executor/data/img_gradient.ppm",
          "Executor/data/img_checkerboard.ppm",
          "Executor/data/img_rings.ppm"
        ],
        "slot": 10,
        "binary": true,
        "cycle": true
      }}
    },

    {
      "id": "group",
      "deps": ["load"],
      "kind": { "WasmGrouping": {
        "stages": [
          { "func": "img_load_ppm",   "arg0": 10, "arg1": 20 },
          { "func": "img_rotate",     "arg0": 20, "arg1": 30 },
          { "func": "img_grayscale",  "arg0": 30, "arg1": 40 },
          { "func": "img_equalize",   "arg0": 40, "arg1": 50 },
          { "func": "img_blur",       "arg0": 50, "arg1": 60 },
          { "func": "img_export_ppm", "arg0": 60, "arg1": 1  }
        ]
      }}
    },

    {
      "id": "save",
      "deps": ["group"],
      "kind": { "Output": {
        "paths": [
          "/tmp/img_grouping_out/gradient_processed.pgm",
          "/tmp/img_grouping_out/checkerboard_processed.pgm",
          "/tmp/img_grouping_out/rings_processed.pgm"
        ],
        "slot": 1
      }}
    },

    {
      "id": "free",
      "deps": ["save"],
      "kind": { "FreeSlots": {
        "stream": [20, 30, 40, 50, 60],
        "io": [10, 1]
      }}
    }
  ]
}
