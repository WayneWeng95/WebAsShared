{
  "_comment": "Image grouping demo: sequential 6-stage chain per image, one at a time.",
  "_comment2": "Uses unified Grouping node. Run with: node-agent run (Rust) or node-agent run --python (Python).",
  "shm_path": "/dev/shm/img_grouping_demo",
  "wasm_path": "Executor/target/wasm32-unknown-unknown/release/guest.wasm",
  "log_level": "info",
  "mode": "reset",
  "runs": 3,

  "nodes": [
    {
      "id": "load",
      "deps": [],
      "kind": { "Input": {
        "paths": [
          "Executor/data/img_gradient.ppm",
          "Executor/data/img_checkerboard.ppm",
          "Executor/data/img_rings.ppm"
        ],
        "slot": 10,
        "binary": true,
        "cycle": true
      }}
    },

    {
      "id": "group",
      "deps": ["load"],
      "kind": { "Grouping": {
        "stages": [
          { "func": "img_load_ppm", "arg": 10, "arg2": 20 },
          { "func": "img_rotate",   "arg": 20, "arg2": 30 },
          { "func": "img_grayscale","arg": 30, "arg2": 40 },
          { "func": "img_equalize", "arg": 40, "arg2": 50 },
          { "func": "img_blur",     "arg": 50, "arg2": 60 },
          { "func": "img_export_ppm","arg": 60, "arg2": 1  }
        ]
      }}
    },

    {
      "id": "save",
      "deps": ["group"],
      "kind": { "Output": {
        "paths": [
          "/tmp/img_grouping_out/gradient_processed.pgm",
          "/tmp/img_grouping_out/checkerboard_processed.pgm",
          "/tmp/img_grouping_out/rings_processed.pgm"
        ],
        "slot": 1
      }}
    },

    {
      "id": "free",
      "deps": ["save"],
      "kind": { "FreeSlots": {
        "stream": [20, 30, 40, 50, 60],
        "io": [10, 1]
      }}
    }
  ]
}
