{
  "_comment": "RDMA ML Training (Python) — Node 1 (receiver + validator).",
  "_comment2": "Runs its own training pipeline, receives node 0's trained stumps,",
  "_comment3": "merges both, and validates the ensemble.",
  "shm_path": "/dev/shm/rdma_py_ml_node1",
  "wasm_path": "Executor/target/wasm32-unknown-unknown/release/guest.wasm",
  "python_script": "Executor/py_guest/python/runner.py",
  "python_wasm": "/opt/myapp/python-3.12.0.wasm",
  "log_level": "info",
  "rdma": {
    "node_id": 1,
    "total": 2,
    "ips": ["192.168.1.10", "192.168.1.11"],
    "transfer": true
  },
  "nodes": [

    { "id": "load", "deps": [],
      "kind": { "Input": { "path": "Executor/data/mnist_features.csv", "slot": 0, "prefetch": true } } },

    { "id": "partition", "deps": ["load"],
      "kind": { "PyFunc": { "func": "ml_partition", "arg": 2, "arg2": 10 } } },

    { "id": "pca_0", "deps": ["partition"], "kind": { "PyFunc": { "func": "ml_pca", "arg": 10, "arg2": 110 } } },
    { "id": "pca_1", "deps": ["partition"], "kind": { "PyFunc": { "func": "ml_pca", "arg": 11, "arg2": 111 } } },

    { "id": "aggregate_pca", "deps": ["pca_0", "pca_1"],
      "kind": { "Aggregate": { "upstream": [110, 111], "downstream": 200 } } },

    { "id": "distribute_train", "deps": ["aggregate_pca"],
      "kind": { "PyFunc": { "func": "ml_redistribute", "arg": 200, "arg2": 8 } } },

    { "id": "train_0", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 30, "arg2": 130 } } },
    { "id": "train_1", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 31, "arg2": 131 } } },
    { "id": "train_2", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 32, "arg2": 132 } } },
    { "id": "train_3", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 33, "arg2": 133 } } },
    { "id": "train_4", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 34, "arg2": 134 } } },
    { "id": "train_5", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 35, "arg2": 135 } } },
    { "id": "train_6", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 36, "arg2": 136 } } },
    { "id": "train_7", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 37, "arg2": 137 } } },

    { "id": "aggregate_train_local",
      "deps": ["train_0","train_1","train_2","train_3","train_4","train_5","train_6","train_7"],
      "kind": { "Aggregate": { "upstream": [130, 131, 132, 133, 134, 135, 136, 137], "downstream": 300 } } },

    { "_comment": "─── Receive node 0's trained stumps into slot 301 ────────────────────────────",
      "id": "recv", "deps": ["distribute_train"],
      "kind": { "RemoteRecv": { "slot": 301, "slot_kind": "Stream", "peer": 0 } } },

    { "_comment": "─── Merge local stumps (300) + remote stumps (301) + PCA test data (200) ─────",
      "id": "aggregate_global", "deps": ["aggregate_train_local", "recv"],
      "kind": { "Aggregate": { "upstream": [300, 301, 200], "downstream": 400 } } },

    { "id": "validate", "deps": ["aggregate_global"],
      "kind": { "PyFunc": { "func": "ml_validate", "arg": 400 } } },

    { "id": "save", "deps": ["validate"],
      "kind": { "Output": { "path": "/tmp/rdma_py_ml_training_result.txt", "slot": 1 } } }

  ]
}
