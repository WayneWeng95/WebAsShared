{
  "_comment": "RDMA FINRA (Rust/WASM) — Node 0 (sender).",
  "shm_path": "/dev/shm/rdma_finra_node0",
  "log_level": "info",
  "rdma": {
    "node_id": 0,
    "total": 2,
    "ips": ["192.168.1.10", "192.168.1.11"],
    "transfer": true
  },
  "nodes": [

    { "id": "load_trades", "deps": [],
      "kind": { "Input": { "path": "../data/trades.csv", "slot": 0, "prefetch": true } } },

    { "id": "fetch_private", "deps": ["load_trades"],
      "kind": { "WasmVoid": { "func": "finra_fetch_private", "arg": 0 } } },

    { "id": "fetch_public", "deps": [],
      "kind": { "WasmVoid": { "func": "finra_fetch_public", "arg": 0 } } },

    { "id": "aggregate_inputs", "deps": ["fetch_private", "fetch_public"],
      "kind": { "Aggregate": { "upstream": [5, 6], "downstream": 200 } } },

    { "id": "rule_0", "deps": ["aggregate_inputs"], "kind": { "WasmVoid": { "func": "finra_audit_rule", "arg": 0 } } },
    { "id": "rule_1", "deps": ["aggregate_inputs"], "kind": { "WasmVoid": { "func": "finra_audit_rule", "arg": 1 } } },
    { "id": "rule_2", "deps": ["aggregate_inputs"], "kind": { "WasmVoid": { "func": "finra_audit_rule", "arg": 2 } } },
    { "id": "rule_3", "deps": ["aggregate_inputs"], "kind": { "WasmVoid": { "func": "finra_audit_rule", "arg": 3 } } },
    { "id": "rule_4", "deps": ["aggregate_inputs"], "kind": { "WasmVoid": { "func": "finra_audit_rule", "arg": 4 } } },
    { "id": "rule_5", "deps": ["aggregate_inputs"], "kind": { "WasmVoid": { "func": "finra_audit_rule", "arg": 5 } } },
    { "id": "rule_6", "deps": ["aggregate_inputs"], "kind": { "WasmVoid": { "func": "finra_audit_rule", "arg": 6 } } },
    { "id": "rule_7", "deps": ["aggregate_inputs"], "kind": { "WasmVoid": { "func": "finra_audit_rule", "arg": 7 } } },

    { "id": "aggregate_rules", "deps": ["rule_0","rule_1","rule_2","rule_3","rule_4","rule_5","rule_6","rule_7"],
      "kind": { "Aggregate": { "upstream": [10, 11, 12, 13, 14, 15, 16, 17], "downstream": 300 } } },

    { "id": "send", "deps": ["aggregate_rules"],
      "kind": { "RemoteSend": { "slot": 300, "slot_kind": "Stream", "peer": 1 } } }

  ]
}
