{
  "_comment": "RDMA Word Count (large, ~50 MiB corpus) — Node 0 (sender).  Run this DAG on machine 0.",
  "_comment2": "Node 0 computes its local word-count aggregate then sends slot 200 to node 1.",
  "_comment3": "Corpus is 50 MiB — fits inside INITIAL_SHM_SIZE=64 MiB by itself, but the combined",
  "_comment4": "bump usage of I/O slot 0 plus per-stage stream slots can push past MR1.  When that",
  "_comment5": "happens, sender-side MR-src-ext / MR-src-stage cover the extension pages automatically.",
  "shm_path": "/dev/shm/rdma_wc_large_node0",
  "wasm_path": "Executor/target/wasm32-unknown-unknown/release/guest.wasm",
  "log_level": "info",
  "rdma": {
    "node_id": 0,
    "total": 2,
    "ips": ["192.168.1.10", "192.168.1.11"],
    "transfer": true
  },
  "nodes": [

    {
      "_comment": "─── Stage 1: load 50 MiB corpus into I/O slot 0 ────────────────────────────",
      "id": "load",
      "deps": [],
      "kind": { "Input": { "path": "Executor/data/corpus_large.txt", "slot": 0, "prefetch": true } }
    },

    {
      "_comment": "─── Stage 2: distribute lines round-robin into stream slots 10–19 ───────────",
      "id": "distribute",
      "deps": ["load"],
      "kind": { "WasmVoid": { "func": "wc_distribute", "arg": 10 } }
    },

    {
      "_comment": "─── Stage 3: 10 parallel map workers ────────────────────────────────────────",
      "id": "map_0", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 10 } }
    },
    { "id": "map_1", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 11 } } },
    { "id": "map_2", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 12 } } },
    { "id": "map_3", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 13 } } },
    { "id": "map_4", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 14 } } },
    { "id": "map_5", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 15 } } },
    { "id": "map_6", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 16 } } },
    { "id": "map_7", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 17 } } },
    { "id": "map_8", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 18 } } },
    { "id": "map_9", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 19 } } },

    {
      "_comment": "─── Stage 4: merge all 10 mapper outputs into stream slot 200 ───────────────",
      "id": "aggregate",
      "deps": ["map_0","map_1","map_2","map_3","map_4","map_5","map_6","map_7","map_8","map_9"],
      "kind": {
        "Aggregate": {
          "upstream": [110, 111, 112, 113, 114, 115, 116, 117, 118, 119],
          "downstream": 200
        }
      }
    },

    {
      "_comment": "─── Stage 5: send local aggregate (slot 200) to node 1 via RDMA ─────────────",
      "id": "send",
      "deps": ["aggregate"],
      "kind": { "RemoteSend": { "slot": 200, "slot_kind": "Stream", "peer": 1 } }
    }

  ]
}
