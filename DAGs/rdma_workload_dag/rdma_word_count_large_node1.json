{
  "_comment": "RDMA Word Count (large, ~50 MiB corpus) — Node 1 (receiver + global reducer).  Run on machine 1.",
  "_comment2": "Node 1 computes its own local aggregate (slot 200), receives node 0's aggregate",
  "_comment3": "into slot 201, merges both into slot 300, then reduces to produce the final count.",
  "_comment4": "If node 0's aggregate happens to exceed MR1's remaining bump budget, the receiver",
  "_comment5": "automatically routes the transfer through MR2 and memcpys back into slot 201.",
  "shm_path": "/dev/shm/rdma_wc_large_node1",
  "wasm_path": "Executor/target/wasm32-unknown-unknown/release/guest.wasm",
  "log_level": "info",
  "rdma": {
    "node_id": 1,
    "total": 2,
    "ips": ["192.168.1.10", "192.168.1.11"],
    "transfer": true
  },
  "nodes": [

    {
      "_comment": "─── Stage 1: load 50 MiB corpus into I/O slot 0 ────────────────────────────",
      "id": "load",
      "deps": [],
      "kind": { "Input": { "path": "Executor/data/corpus_large.txt", "slot": 0, "prefetch": true } }
    },

    {
      "_comment": "─── Stage 2: distribute lines round-robin into stream slots 10–19 ───────────",
      "id": "distribute",
      "deps": ["load"],
      "kind": { "WasmVoid": { "func": "wc_distribute", "arg": 10 } }
    },

    {
      "_comment": "─── Stage 3: 10 parallel map workers ────────────────────────────────────────",
      "id": "map_0", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 10 } }
    },
    { "id": "map_1", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 11 } } },
    { "id": "map_2", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 12 } } },
    { "id": "map_3", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 13 } } },
    { "id": "map_4", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 14 } } },
    { "id": "map_5", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 15 } } },
    { "id": "map_6", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 16 } } },
    { "id": "map_7", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 17 } } },
    { "id": "map_8", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 18 } } },
    { "id": "map_9", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 19 } } },

    {
      "_comment": "─── Stage 4: local aggregate into stream slot 200 ───────────────────────────",
      "id": "aggregate_local",
      "deps": ["map_0","map_1","map_2","map_3","map_4","map_5","map_6","map_7","map_8","map_9"],
      "kind": {
        "Aggregate": {
          "upstream": [110, 111, 112, 113, 114, 115, 116, 117, 118, 119],
          "downstream": 200
        }
      }
    },

    {
      "_comment": "─── Stage 5: receive node 0's aggregate into stream slot 201 ────────────────",
      "_comment2": "Runs concurrently with aggregate_local (no shared deps after distribute).",
      "id": "recv",
      "deps": ["distribute"],
      "kind": { "RemoteRecv": { "slot": 201, "slot_kind": "Stream", "peer": 0 } }
    },

    {
      "_comment": "─── Stage 6: merge local (200) + remote (201) into slot 300 ─────────────────",
      "id": "aggregate_global",
      "deps": ["aggregate_local", "recv"],
      "kind": {
        "Aggregate": {
          "upstream": [200, 201],
          "downstream": 300
        }
      }
    },

    {
      "_comment": "─── Stage 7: reduce — sum per-word counts across both nodes ─────────────────",
      "id": "reduce",
      "deps": ["aggregate_global"],
      "kind": { "WasmVoid": { "func": "wc_reduce", "arg": 300 } }
    },

    {
      "_comment": "─── Stage 8: flush OUTPUT_IO_SLOT to disk ───────────────────────────────────",
      "id": "save",
      "deps": ["reduce"],
      "kind": { "Output": { "path": "/tmp/rdma_word_count_large_result.txt" } }
    }

  ]
}
