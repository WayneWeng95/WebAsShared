{
  "_comment": "TF-IDF feature extraction on corpus.txt.",
  "_comment2": "Distribute -> parallel tfidf_map x8 -> aggregate -> tfidf_reduce (top-50).",
  "_comment3": "Uses unified Func nodes. Run with: node-agent run (Rust) or node-agent run --python (Python).",
  "shm_path": "/dev/shm/tfidf_demo",
  "wasm_path": "Executor/target/wasm32-unknown-unknown/release/guest.wasm",
  "log_level": "info",
  "nodes": [

    {
      "id": "load",
      "deps": [],
      "kind": { "Input": { "path": "Executor/data/corpus.txt", "slot": 0, "prefetch": true } }
    },

    {
      "_comment": "Distribute lines round-robin into stream slots 10-17",
      "id": "distribute",
      "deps": ["load"],
      "kind": { "Func": { "func": "wc_distribute", "arg": 8, "arg2": 10 } }
    },

    {
      "_comment": "8 parallel TF-IDF map workers",
      "id": "map_0", "deps": ["distribute"], "kind": { "Func": { "func": "tfidf_map", "arg": 10, "arg2": 110 } }
    },
    { "id": "map_1", "deps": ["distribute"], "kind": { "Func": { "func": "tfidf_map", "arg": 11, "arg2": 111 } } },
    { "id": "map_2", "deps": ["distribute"], "kind": { "Func": { "func": "tfidf_map", "arg": 12, "arg2": 112 } } },
    { "id": "map_3", "deps": ["distribute"], "kind": { "Func": { "func": "tfidf_map", "arg": 13, "arg2": 113 } } },
    { "id": "map_4", "deps": ["distribute"], "kind": { "Func": { "func": "tfidf_map", "arg": 14, "arg2": 114 } } },
    { "id": "map_5", "deps": ["distribute"], "kind": { "Func": { "func": "tfidf_map", "arg": 15, "arg2": 115 } } },
    { "id": "map_6", "deps": ["distribute"], "kind": { "Func": { "func": "tfidf_map", "arg": 16, "arg2": 116 } } },
    { "id": "map_7", "deps": ["distribute"], "kind": { "Func": { "func": "tfidf_map", "arg": 17, "arg2": 117 } } },

    {
      "id": "aggregate",
      "deps": ["map_0","map_1","map_2","map_3","map_4","map_5","map_6","map_7"],
      "kind": { "Aggregate": { "upstream": [110, 111, 112, 113, 114, 115, 116, 117], "downstream": 200 } }
    },

    {
      "id": "reduce",
      "deps": ["aggregate"],
      "kind": { "Func": { "func": "tfidf_reduce", "arg": 200 } }
    },

    {
      "id": "save",
      "deps": ["reduce"],
      "kind": { "Output": { "path": "/tmp/tfidf_result.txt" } }
    }

  ]
}
