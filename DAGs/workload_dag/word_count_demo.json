{
  "_comment": "Word count pipeline: distribute -> parallel map x10 -> aggregate -> reduce.",
  "_comment2": "Uses unified Func nodes. Run with: node-agent run (Rust) or node-agent run --python (Python).",
  "shm_path": "/dev/shm/word_count_demo",
  "wasm_path": "Executor/target/wasm32-unknown-unknown/release/guest.wasm",
  "log_level": "info",
  "nodes": [

    {
      "id": "load",
      "deps": [],
      "kind": { "Input": { "path": "Executor/data/corpus.txt", "slot": 0, "prefetch": true } }
    },

    {
      "_comment": "Distribute lines round-robin into stream slots 10-19",
      "id": "distribute",
      "deps": ["load"],
      "kind": { "Func": { "func": "wc_distribute", "arg": 10, "arg2": 10 } }
    },

    {
      "_comment": "10 parallel map workers: each reads slot N, writes to slot N+100",
      "id": "map_0", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 10, "arg2": 110 } }
    },
    { "id": "map_1", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 11, "arg2": 111 } } },
    { "id": "map_2", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 12, "arg2": 112 } } },
    { "id": "map_3", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 13, "arg2": 113 } } },
    { "id": "map_4", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 14, "arg2": 114 } } },
    { "id": "map_5", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 15, "arg2": 115 } } },
    { "id": "map_6", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 16, "arg2": 116 } } },
    { "id": "map_7", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 17, "arg2": 117 } } },
    { "id": "map_8", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 18, "arg2": 118 } } },
    { "id": "map_9", "deps": ["distribute"], "kind": { "Func": { "func": "wc_map", "arg": 19, "arg2": 119 } } },

    {
      "id": "aggregate",
      "deps": ["map_0","map_1","map_2","map_3","map_4","map_5","map_6","map_7","map_8","map_9"],
      "kind": { "Aggregate": { "upstream": [110, 111, 112, 113, 114, 115, 116, 117, 118, 119], "downstream": 200 } }
    },

    {
      "id": "reduce",
      "deps": ["aggregate"],
      "kind": { "Func": { "func": "wc_reduce", "arg": 200 } }
    },

    {
      "id": "save",
      "deps": ["reduce"],
      "kind": { "Output": { "path": "/tmp/word_count_result.txt" } }
    }

  ]
}
