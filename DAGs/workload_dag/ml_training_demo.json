{
  "_comment": "ML Training workflow: image classification pipeline.",
  "_comment2": "Partition -> PCA x2 -> Redistribute -> Train x8 -> Aggregate -> Validate.",
  "_comment3": "Uses unified Func nodes. Run with: node-agent run (Rust) or node-agent run --python (Python).",
  "shm_path": "/dev/shm/ml_training_demo",
  "wasm_path": "Executor/target/wasm32-unknown-unknown/release/guest.wasm",
  "log_level": "info",
  "nodes": [

    { "id": "load", "deps": [],
      "kind": { "Input": { "path": "Executor/data/mnist_features.csv", "slot": 0, "prefetch": true } } },

    { "_comment": "Partition dataset into 2 shards (slots 10-11)",
      "id": "partition", "deps": ["load"],
      "kind": { "Func": { "func": "ml_partition", "arg": 2, "arg2": 10 } } },

    { "_comment": "PCA x2: power-iteration feature extraction",
      "id": "pca_0", "deps": ["partition"], "kind": { "Func": { "func": "ml_pca", "arg": 10, "arg2": 110 } } },
    { "id": "pca_1", "deps": ["partition"], "kind": { "Func": { "func": "ml_pca", "arg": 11, "arg2": 111 } } },

    { "id": "aggregate_pca", "deps": ["pca_0", "pca_1"],
      "kind": { "Aggregate": { "upstream": [110, 111], "downstream": 200 } } },

    { "_comment": "Redistribute PCA output to 8 training shards (slots 30-37)",
      "id": "redistribute", "deps": ["aggregate_pca"],
      "kind": { "Func": { "func": "ml_redistribute", "arg": 200, "arg2": 8 } } },

    { "_comment": "Train x8: decision stump trainers",
      "id": "train_0", "deps": ["redistribute"], "kind": { "Func": { "func": "ml_train", "arg": 30, "arg2": 130 } } },
    { "id": "train_1", "deps": ["redistribute"], "kind": { "Func": { "func": "ml_train", "arg": 31, "arg2": 131 } } },
    { "id": "train_2", "deps": ["redistribute"], "kind": { "Func": { "func": "ml_train", "arg": 32, "arg2": 132 } } },
    { "id": "train_3", "deps": ["redistribute"], "kind": { "Func": { "func": "ml_train", "arg": 33, "arg2": 133 } } },
    { "id": "train_4", "deps": ["redistribute"], "kind": { "Func": { "func": "ml_train", "arg": 34, "arg2": 134 } } },
    { "id": "train_5", "deps": ["redistribute"], "kind": { "Func": { "func": "ml_train", "arg": 35, "arg2": 135 } } },
    { "id": "train_6", "deps": ["redistribute"], "kind": { "Func": { "func": "ml_train", "arg": 36, "arg2": 136 } } },
    { "id": "train_7", "deps": ["redistribute"], "kind": { "Func": { "func": "ml_train", "arg": 37, "arg2": 137 } } },

    { "id": "aggregate_train",
      "deps": ["train_0","train_1","train_2","train_3","train_4","train_5","train_6","train_7"],
      "kind": { "Aggregate": { "upstream": [130, 131, 132, 133, 134, 135, 136, 137, 200], "downstream": 300 } } },

    { "_comment": "Validate: ensemble stumps, compute accuracy",
      "id": "validate", "deps": ["aggregate_train"],
      "kind": { "Func": { "func": "ml_validate", "arg": 300 } } },

    { "id": "save", "deps": ["validate"],
      "kind": { "Output": { "path": "/tmp/ml_training_result.txt" } } }

  ]
}
