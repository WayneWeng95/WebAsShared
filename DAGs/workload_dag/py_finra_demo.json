{
  "_comment": "FINRA audit workflow (Python): financial trade validation pipeline.",
  "_comment2": "Modeled after the FINRA serverless workflow from RMMAP (EuroSys'24).",
  "_comment3": "4 stages: FetchPrivate || FetchPublic → RunAuditRule ×8 → MergeResults.",
  "shm_path": "/dev/shm/py_finra_demo",
  "python_script": "../py_guest/python/runner.py",
  "python_wasm": "/opt/myapp/python-3.12.0.wasm",
  "log_level": "info",
  "nodes": [

    {
      "_comment": "─── Load trades CSV into I/O slot 0 ─────────────────────────────────────────",
      "id": "load_trades",
      "deps": [],
      "kind": { "Input": { "path": "../data/trades.csv", "slot": 0, "prefetch": true } }
    },

    {
      "_comment": "─── Stage 1a: FetchPrivateData — parse trades CSV → stream slot 5 ───────────",
      "id": "fetch_private",
      "deps": ["load_trades"],
      "kind": { "PyFunc": { "func": "finra_fetch_private", "arg": 0, "arg2": 5 } }
    },

    {
      "_comment": "─── Stage 1b: FetchPublicData — generate market reference → stream slot 6 ───",
      "id": "fetch_public",
      "deps": [],
      "kind": { "PyFunc": { "func": "finra_fetch_public", "arg": 6 } }
    },

    {
      "_comment": "─── Aggregate trade data + market reference into stream slot 200 ─────────────",
      "id": "aggregate_inputs",
      "deps": ["fetch_private", "fetch_public"],
      "kind": {
        "Aggregate": {
          "upstream": [5, 6],
          "downstream": 200
        }
      }
    },

    {
      "_comment": "─── Stage 2: 8 parallel RunAuditRule workers ─────────────────────────────────",
      "id": "rule_0", "deps": ["aggregate_inputs"], "kind": { "PyFunc": { "func": "finra_audit_rule", "arg": 200, "arg2": 0 } }
    },
    { "id": "rule_1", "deps": ["aggregate_inputs"], "kind": { "PyFunc": { "func": "finra_audit_rule", "arg": 200, "arg2": 1 } } },
    { "id": "rule_2", "deps": ["aggregate_inputs"], "kind": { "PyFunc": { "func": "finra_audit_rule", "arg": 200, "arg2": 2 } } },
    { "id": "rule_3", "deps": ["aggregate_inputs"], "kind": { "PyFunc": { "func": "finra_audit_rule", "arg": 200, "arg2": 3 } } },
    { "id": "rule_4", "deps": ["aggregate_inputs"], "kind": { "PyFunc": { "func": "finra_audit_rule", "arg": 200, "arg2": 4 } } },
    { "id": "rule_5", "deps": ["aggregate_inputs"], "kind": { "PyFunc": { "func": "finra_audit_rule", "arg": 200, "arg2": 5 } } },
    { "id": "rule_6", "deps": ["aggregate_inputs"], "kind": { "PyFunc": { "func": "finra_audit_rule", "arg": 200, "arg2": 6 } } },
    { "id": "rule_7", "deps": ["aggregate_inputs"], "kind": { "PyFunc": { "func": "finra_audit_rule", "arg": 200, "arg2": 7 } } },

    {
      "_comment": "─── Aggregate all rule outputs into stream slot 300 ──────────────────────────",
      "id": "aggregate_rules",
      "deps": ["rule_0","rule_1","rule_2","rule_3","rule_4","rule_5","rule_6","rule_7"],
      "kind": {
        "Aggregate": {
          "upstream": [10, 11, 12, 13, 14, 15, 16, 17],
          "downstream": 300
        }
      }
    },

    {
      "_comment": "─── Stage 3: MergeResults — summarize all audit outcomes ─────────────────────",
      "id": "merge",
      "deps": ["aggregate_rules"],
      "kind": { "PyFunc": { "func": "finra_merge_results", "arg": 300 } }
    },

    {
      "id": "save",
      "deps": ["merge"],
      "kind": { "Output": { "path": "/tmp/py_finra_result.txt", "slot": 1 } }
    }

  ]
}
