{
  "_comment": "FINRA audit workflow: financial trade validation pipeline.",
  "_comment2": "4 stages: FetchPrivate || FetchPublic -> RunAuditRule x8 -> MergeResults.",
  "_comment3": "Uses unified Func nodes. Run with: node-agent run (Rust) or node-agent run --python (Python).",
  "shm_path": "/dev/shm/finra_demo",
  "wasm_path": "Executor/target/wasm32-unknown-unknown/release/guest.wasm",
  "log_level": "info",
  "nodes": [

    {
      "id": "load_trades",
      "deps": [],
      "kind": { "Input": { "path": "Executor/data/trades.csv", "slot": 0, "prefetch": true } }
    },

    {
      "_comment": "FetchPrivateData: parse trades CSV -> stream slot 5",
      "id": "fetch_private",
      "deps": ["load_trades"],
      "kind": { "Func": { "func": "finra_fetch_private", "arg": 0, "arg2": 5 } }
    },

    {
      "_comment": "FetchPublicData: market reference -> stream slot 6. Rust ignores slot arg (hardcoded).",
      "id": "fetch_public",
      "deps": [],
      "kind": { "Func": { "func": "finra_fetch_public", "arg": 6, "wasm_arg": 0 } }
    },

    {
      "id": "aggregate_inputs",
      "deps": ["fetch_private", "fetch_public"],
      "kind": { "Aggregate": { "upstream": [5, 6], "downstream": 200 } }
    },

    {
      "_comment": "8 parallel RunAuditRule workers. Rust uses rule_id as sole arg; Python takes (input_slot, rule_id).",
      "id": "rule_0", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 0, "wasm_arg": 0 } }
    },
    { "id": "rule_1", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 1, "wasm_arg": 1 } } },
    { "id": "rule_2", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 2, "wasm_arg": 2 } } },
    { "id": "rule_3", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 3, "wasm_arg": 3 } } },
    { "id": "rule_4", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 4, "wasm_arg": 4 } } },
    { "id": "rule_5", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 5, "wasm_arg": 5 } } },
    { "id": "rule_6", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 6, "wasm_arg": 6 } } },
    { "id": "rule_7", "deps": ["aggregate_inputs"], "kind": { "Func": { "func": "finra_audit_rule", "arg": 200, "arg2": 7, "wasm_arg": 7 } } },

    {
      "id": "aggregate_rules",
      "deps": ["rule_0","rule_1","rule_2","rule_3","rule_4","rule_5","rule_6","rule_7"],
      "kind": { "Aggregate": { "upstream": [10, 11, 12, 13, 14, 15, 16, 17], "downstream": 300 } }
    },

    {
      "_comment": "MergeResults: summarize violations",
      "id": "merge",
      "deps": ["aggregate_rules"],
      "kind": { "Func": { "func": "finra_merge_results", "arg": 300 } }
    },

    {
      "id": "save",
      "deps": ["merge"],
      "kind": { "Output": { "path": "/tmp/finra_result.txt" } }
    }

  ]
}
