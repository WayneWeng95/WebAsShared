{
  "_comment": "ML Training workflow (Python): image classification pipeline.",
  "_comment2": "Modeled after ML training from RMMAP (EuroSys'24).",
  "_comment3": "Partition → PCA ×2 → Aggregate → Distribute → Train ×8 → Aggregate → Validate.",
  "shm_path": "/dev/shm/py_ml_training_demo",
  "wasm_path": "Executor/target/wasm32-unknown-unknown/release/guest.wasm",
  "python_script": "Executor/py_guest/python/runner.py",
  "python_wasm": "/opt/myapp/python-3.12.0.wasm",
  "log_level": "info",
  "nodes": [

    {
      "_comment": "─── Load MNIST features CSV into I/O slot 0 ─────────────────────────────────",
      "id": "load",
      "deps": [],
      "kind": { "Input": { "path": "Executor/data/mnist_features.csv", "slot": 0, "prefetch": true } }
    },

    {
      "_comment": "─── Stage 1: Partition dataset into 2 shards (for 2 PCA workers) ────────────",
      "id": "partition",
      "deps": ["load"],
      "kind": { "PyFunc": { "func": "ml_partition", "arg": 2, "arg2": 10 } }
    },

    {
      "_comment": "─── Stage 2: PCA feature extraction (2 parallel workers) ────────────────────",
      "id": "pca_0", "deps": ["partition"],
      "kind": { "PyFunc": { "func": "ml_pca", "arg": 10, "arg2": 110 } }
    },
    {
      "id": "pca_1", "deps": ["partition"],
      "kind": { "PyFunc": { "func": "ml_pca", "arg": 11, "arg2": 111 } }
    },

    {
      "_comment": "─── Aggregate PCA outputs → slot 200 ────────────────────────────────────────",
      "id": "aggregate_pca",
      "deps": ["pca_0", "pca_1"],
      "kind": { "Aggregate": { "upstream": [110, 111], "downstream": 200 } }
    },

    {
      "_comment": "─── Re-distribute PCA features to 8 training shards (slots 30–37) ───────────",
      "id": "distribute_train",
      "deps": ["aggregate_pca"],
      "kind": { "PyFunc": { "func": "ml_redistribute", "arg": 200, "arg2": 8 } }
    },

    {
      "_comment": "─── Stage 3: 8 parallel decision stump trainers ──────────────────────────────",
      "id": "train_0", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 30, "arg2": 130 } }
    },
    { "id": "train_1", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 31, "arg2": 131 } } },
    { "id": "train_2", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 32, "arg2": 132 } } },
    { "id": "train_3", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 33, "arg2": 133 } } },
    { "id": "train_4", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 34, "arg2": 134 } } },
    { "id": "train_5", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 35, "arg2": 135 } } },
    { "id": "train_6", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 36, "arg2": 136 } } },
    { "id": "train_7", "deps": ["distribute_train"], "kind": { "PyFunc": { "func": "ml_train", "arg": 37, "arg2": 137 } } },

    {
      "_comment": "─── Aggregate all stump models + PCA test data → slot 300 ────────────────────",
      "id": "aggregate_train",
      "deps": ["train_0","train_1","train_2","train_3","train_4","train_5","train_6","train_7"],
      "kind": {
        "Aggregate": {
          "upstream": [130, 131, 132, 133, 134, 135, 136, 137, 200],
          "downstream": 300
        }
      }
    },

    {
      "_comment": "─── Stage 4: Validation — ensemble stumps, compute accuracy ──────────────────",
      "id": "validate",
      "deps": ["aggregate_train"],
      "kind": { "PyFunc": { "func": "ml_validate", "arg": 300 } }
    },

    {
      "id": "save",
      "deps": ["validate"],
      "kind": { "Output": { "path": "/tmp/py_ml_training_result.txt", "slot": 1 } }
    }

  ]
}
