{
  "shm_path": "/dev/shm/word_count_demo",
  "log_level": "info",
  "nodes": [

    {
      "_comment": "─── Stage 1: load corpus into I/O slot 0, one record per line ───────────────",
      "id": "load",
      "deps": [],
      "kind": { "Input": { "path": "../data/corpus.txt", "slot": 0, "prefetch": true } }
    },

    {
      "_comment": "─── Stage 2: distribute lines round-robin into stream slots 10–19 ───────────",
      "id": "distribute",
      "deps": ["load"],
      "kind": { "WasmVoid": { "func": "wc_distribute", "arg": 10 } }
    },

    {
      "_comment": "─── Stage 3: 10 parallel map workers ────────────────────────────────────────",
      "_comment2": "Each reads stream slot N and writes word=<w>\\x1f<count> to stream slot N+100.",
      "id": "map_0", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 10 } }
    },
    { "id": "map_1", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 11 } } },
    { "id": "map_2", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 12 } } },
    { "id": "map_3", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 13 } } },
    { "id": "map_4", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 14 } } },
    { "id": "map_5", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 15 } } },
    { "id": "map_6", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 16 } } },
    { "id": "map_7", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 17 } } },
    { "id": "map_8", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 18 } } },
    { "id": "map_9", "deps": ["distribute"], "kind": { "WasmVoid": { "func": "wc_map", "arg": 19 } } },

    {
      "_comment": "─── Stage 4: merge all 10 mapper outputs into stream slot 200 ───────────────",
      "id": "aggregate",
      "deps": ["map_0","map_1","map_2","map_3","map_4","map_5","map_6","map_7","map_8","map_9"],
      "kind": {
        "Aggregate": {
          "upstream": [110, 111, 112, 113, 114, 115, 116, 117, 118, 119],
          "downstream": 200
        }
      }
    },

    {
      "_comment": "─── Stage 5: reduce — sum per-word counts across all mappers ────────────────",
      "id": "reduce",
      "deps": ["aggregate"],
      "kind": { "WasmVoid": { "func": "wc_reduce", "arg": 200 } }
    },

    {
      "_comment": "─── Stage 6: flush OUTPUT_IO_SLOT to disk ───────────────────────────────────",
      "id": "save",
      "deps": ["reduce"],
      "kind": { "Output": { "path": "/tmp/word_count_result.txt" } }
    }

  ]
}
