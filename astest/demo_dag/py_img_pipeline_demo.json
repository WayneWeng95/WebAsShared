{
  "shm_path": "/dev/shm/py_img_pipeline_demo",
  "python_script": "../py_guest/python/runner.py",
  "python_wasm": "/opt/myapp/python-3.12.0.wasm",
  "log_level": "info",
  "mode": "reset",
  "runs": 3,

  "nodes": [
    {
      "id": "load",
      "deps": [],
      "kind": { "Input": {
        "paths": [
          "../data/img_gradient.ppm",
          "../data/img_checkerboard.ppm",
          "../data/img_rings.ppm"
        ],
        "slot": 10,
        "binary": true
      }}
    },

    {
      "id": "pipeline",
      "deps": ["load"],
      "kind": { "PyPipeline": {
        "rounds": 3,
        "stages": [
          { "func": "img_load_ppm_binary", "arg": 10, "arg2": 20 },
          { "func": "img_rotate",          "arg": 20, "arg2": 30 },
          { "func": "img_grayscale",       "arg": 30, "arg2": 40 },
          { "func": "img_equalize",        "arg": 40, "arg2": 50 },
          { "func": "img_blur",            "arg": 50, "arg2": 60 },
          { "func": "img_export_ppm",      "arg": 60, "arg2":  1 }
        ]
      }}
    },

    {
      "id": "save",
      "deps": ["pipeline"],
      "kind": { "Output": {
        "paths": [
          "/tmp/py_img_pipeline_out/gradient_processed.pgm",
          "/tmp/py_img_pipeline_out/checkerboard_processed.pgm",
          "/tmp/py_img_pipeline_out/rings_processed.pgm"
        ],
        "slot": 1
      }}
    },

    {
      "id": "free",
      "deps": ["save"],
      "kind": { "FreeSlots": { "stream": [20, 30, 40, 50, 60], "io": [10, 1] } }
    }
  ]
}
