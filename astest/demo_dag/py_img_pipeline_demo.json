{
  "shm_path": "/dev/shm/py_img_pipeline_demo",
  "python_script": "../py_guest/python/runner.py",
  "python_wasm": "/opt/myapp/python-3.12.0.wasm",
  "log_level": "info",
  "mode": "reset",
  "runs": 3,

  "nodes": [
    {
      "id": "load",
      "deps": [],
      "kind": { "Input": {
        "paths": [
          "../data/img_gradient.ppm",
          "../data/img_checkerboard.ppm",
          "../data/img_rings.ppm"
        ],
        "slot": 10
      }}
    },
    { "id": "parse",    "deps": ["load"],    "kind": { "PyFunc": { "func": "img_load_ppm",  "arg": 0 } } },
    { "id": "rotate",   "deps": ["parse"],   "kind": { "PyFunc": { "func": "img_rotate",    "arg": 0 } } },
    { "id": "gray",     "deps": ["rotate"],  "kind": { "PyFunc": { "func": "img_grayscale", "arg": 0 } } },
    { "id": "equalize", "deps": ["gray"],    "kind": { "PyFunc": { "func": "img_equalize",  "arg": 0 } } },
    { "id": "blur",     "deps": ["equalize"],"kind": { "PyFunc": { "func": "img_blur",      "arg": 0 } } },
    { "id": "export",   "deps": ["blur"],    "kind": { "PyFunc": { "func": "img_export_ppm","arg": 0 } } },
    {
      "id": "save",
      "deps": ["export"],
      "kind": { "Output": {
        "paths": [
          "/tmp/py_img_out/gradient_processed.pgm",
          "/tmp/py_img_out/checkerboard_processed.pgm",
          "/tmp/py_img_out/rings_processed.pgm"
        ]
      }}
    },
    {
      "id": "free",
      "deps": ["save"],
      "kind": { "FreeSlots": { "stream": [20, 30, 40, 50, 60], "io": [10] } }
    }
  ]
}
