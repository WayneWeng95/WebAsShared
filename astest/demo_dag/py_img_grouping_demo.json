{
  "shm_path": "/dev/shm/py_img_grouping_demo",
  "python_script": "../py_guest/python/runner.py",
  "python_wasm": "/opt/myapp/python-3.12.0.wasm",
  "log_level": "info",
  "mode": "reset",
  "runs": 3,

  "nodes": [
    {
      "id": "load",
      "deps": [],
      "kind": { "Input": {
        "paths": [
          "../data/img_gradient.ppm",
          "../data/img_checkerboard.ppm",
          "../data/img_rings.ppm"
        ],
        "slot": 10
      }}
    },
    {
      "id": "pipeline",
      "deps": ["load"],
      "kind": { "PyGrouping": {
        "stages": [
          { "func": "img_load_ppm"   },
          { "func": "img_rotate"     },
          { "func": "img_grayscale"  },
          { "func": "img_equalize"   },
          { "func": "img_blur"       },
          { "func": "img_export_ppm" }
        ]
      }}
    },
    {
      "id": "save",
      "deps": ["pipeline"],
      "kind": { "Output": {
        "paths": [
          "/tmp/py_img_out/gradient_processed.pgm",
          "/tmp/py_img_out/checkerboard_processed.pgm",
          "/tmp/py_img_out/rings_processed.pgm"
        ],
        "slot": 1
      }}
    },
    {
      "id": "free",
      "deps": ["save"],
      "kind": { "FreeSlots": { "stream": [20, 30, 40, 50, 60], "io": [10, 1] } }
    }
  ]
}
