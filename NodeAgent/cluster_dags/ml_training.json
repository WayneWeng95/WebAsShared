{
  "_comment": "ClusterDag: Distributed ML Training (Rust/WASM) across 2 nodes via RDMA.",
  "_comment2": "Node 0: partition -> PCA -> redistribute -> train x8 -> send to node 1.",
  "_comment3": "Node 1: same local pipeline + receive node 0's stumps, merge all, validate.",
  "shm_path_prefix": "/dev/shm/rdma_ml",
  "log_level": "info",
  "transfer": true,
  "node_dags": {
    "0": [
      { "id": "load", "deps": [],
        "kind": { "Input": { "path": "Executor/data/mnist_features.csv", "slot": 0, "prefetch": true } } },

      { "id": "partition", "deps": ["load"],
        "kind": { "WasmVoid": { "func": "ml_partition", "arg": 2 } } },

      { "id": "pca_0", "deps": ["partition"], "kind": { "WasmVoid": { "func": "ml_pca", "arg": 10 } } },
      { "id": "pca_1", "deps": ["partition"], "kind": { "WasmVoid": { "func": "ml_pca", "arg": 11 } } },

      { "id": "aggregate_pca", "deps": ["pca_0", "pca_1"],
        "kind": { "Aggregate": { "upstream": [110, 111], "downstream": 200 } } },

      { "id": "redistribute", "deps": ["aggregate_pca"],
        "kind": { "WasmVoid": { "func": "ml_redistribute", "arg": 200 } } },

      { "id": "train_0", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 30 } } },
      { "id": "train_1", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 31 } } },
      { "id": "train_2", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 32 } } },
      { "id": "train_3", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 33 } } },
      { "id": "train_4", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 34 } } },
      { "id": "train_5", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 35 } } },
      { "id": "train_6", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 36 } } },
      { "id": "train_7", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 37 } } },

      { "id": "aggregate_train",
        "deps": ["train_0","train_1","train_2","train_3","train_4","train_5","train_6","train_7"],
        "kind": { "Aggregate": { "upstream": [130, 131, 132, 133, 134, 135, 136, 137], "downstream": 300 } } },

      { "id": "send", "deps": ["aggregate_train"],
        "kind": { "RemoteSend": { "slot": 300, "slot_kind": "Stream", "peer": 1 } } }
    ],
    "1": [
      { "id": "load", "deps": [],
        "kind": { "Input": { "path": "Executor/data/mnist_features.csv", "slot": 0, "prefetch": true } } },

      { "id": "partition", "deps": ["load"],
        "kind": { "WasmVoid": { "func": "ml_partition", "arg": 2 } } },

      { "id": "pca_0", "deps": ["partition"], "kind": { "WasmVoid": { "func": "ml_pca", "arg": 10 } } },
      { "id": "pca_1", "deps": ["partition"], "kind": { "WasmVoid": { "func": "ml_pca", "arg": 11 } } },

      { "id": "aggregate_pca", "deps": ["pca_0", "pca_1"],
        "kind": { "Aggregate": { "upstream": [110, 111], "downstream": 200 } } },

      { "id": "redistribute", "deps": ["aggregate_pca"],
        "kind": { "WasmVoid": { "func": "ml_redistribute", "arg": 200 } } },

      { "id": "train_0", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 30 } } },
      { "id": "train_1", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 31 } } },
      { "id": "train_2", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 32 } } },
      { "id": "train_3", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 33 } } },
      { "id": "train_4", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 34 } } },
      { "id": "train_5", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 35 } } },
      { "id": "train_6", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 36 } } },
      { "id": "train_7", "deps": ["redistribute"], "kind": { "WasmVoid": { "func": "ml_train", "arg": 37 } } },

      { "id": "aggregate_train_local",
        "deps": ["train_0","train_1","train_2","train_3","train_4","train_5","train_6","train_7"],
        "kind": { "Aggregate": { "upstream": [130, 131, 132, 133, 134, 135, 136, 137], "downstream": 300 } } },

      { "id": "recv", "deps": ["redistribute"],
        "kind": { "RemoteRecv": { "slot": 301, "slot_kind": "Stream", "peer": 0 } } },

      { "id": "aggregate_global", "deps": ["aggregate_train_local", "recv"],
        "kind": { "Aggregate": { "upstream": [300, 301, 200], "downstream": 400 } } },

      { "id": "validate", "deps": ["aggregate_global"],
        "kind": { "WasmVoid": { "func": "ml_validate", "arg": 400 } } },

      { "id": "save", "deps": ["validate"],
        "kind": { "Output": { "path": "/tmp/rdma_ml_training_result.txt" } } }
    ]
  }
}
