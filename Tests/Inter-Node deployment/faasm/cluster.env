# Faasm (track D) cluster topology — single source of truth, git-synced to every
# node. Faasm is clean-slate (no orchestration framework of its own), so we run a
# tiny per-node AGENT that launches Faaslets (wasmtime WASM instances) on its node,
# and a COORDINATOR on node 0 that places Faaslets per node and collects results.
# State moves through the shared Redis (Faasm KV), just like the intra-node baseline
# (../../Intra-Node Application_Benchmark/<W>/baseline/faasm/), only distributed.
#
# Mirrors NodeAgent/agent.toml: node 0 = coordinator, nodes 1-3 = workers.

COORD_IP=10.10.1.2                          # coordinator (node 0)
WORKER_IPS="10.10.1.1 10.10.1.3 10.10.1.4"  # worker nodes (1-3); add 5 more for the 9-node run
AGENT_PORT=9600                             # per-node agent HTTP port

# Shared Faasm KV. Set to NODE 0 (this box) for testing. NOTE: a default Redis is
# in PROTECTED MODE (loopback-only) — workers can't reach 10.10.1.2:6379 until you
# open it on node 0:  redis-cli config set protected-mode no; config set bind 0.0.0.0
# (For headline runs prefer a DEDICATED box off the compute path — fairness §8.)
REDIS_HOST=10.10.1.2
REDIS_PORT=6379

# Faaslet runtime + where staged Faaslet modules / inputs land on each node.
WASMTIME=wasmtime                           # the Faaslet runtime (AOT .cwasm runner)
STAGE_DIR=/tmp/faasm_stage                  # agent writes staged .cwasm/inputs here
