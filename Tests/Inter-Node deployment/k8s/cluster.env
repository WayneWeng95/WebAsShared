# k8s / Knative cluster topology for the inter-node BASELINES.
#   - Cloudburst  → runs on Kubernetes  (executors/scheduler as pods)
#   - RMMap       → runs on Knative      (Service + Sequence/Parallel flows)
# Single source of truth, git-synced to every node. Sourced by the 0x-*.sh scripts.
#
# Mirrors the WasMem cluster (NodeAgent/agent.toml): node 0 = control-plane,
# nodes 1-8 = workers. k3s coexists with the WasMem node-agent on the same boxes
# (different ports) — but run experiments ONE AT A TIME (fairness rule §5.4): k8s
# control-plane + pods steal CPU/RAM from a concurrent WasMem run.

# ── topology ─────────────────────────────────────────────────────────────────
SERVER_IP=10.10.1.2                          # k3s control-plane (node 0 / coordinator)
AGENT_IPS="10.10.1.1 10.10.1.3 10.10.1.4 10.10.1.5 10.10.1.6 10.10.1.7 10.10.1.8 10.10.1.9"  # k3s workers (nodes 1-8)
# NIC to pin node-ip + flannel to the cluster (RoCE) network. Leave empty to use
# the default-route interface (--node-ip already steers k8s to the 10.10.1.x IP).
# On node 0 the 10.10.1.x NIC is `eno1d1` (from `ip -o addr show | grep 10.10.1`);
# set this only if a node's default route is NOT the cluster network.
CLUSTER_IFACE=eno1d1

# ── versions (pinned for reproducibility; bump deliberately) ──────────────────
# Knative v1.14 needs k8s ≥1.28; k3s v1.29 satisfies that. Verify the matrix at
# https://knative.dev/docs/install/ before bumping.
K3S_VERSION="v1.29.6+k3s2"                   # "" = latest stable channel
KNATIVE_VERSION="v1.14.1"                     # knative/serving release tag (knative-<VER>)
KOURIER_VERSION="v1.14.0"                     # knative/net-kourier release tag (no v1.14.1 published; 1.14.0 is the 1.14 line)
STRIMZI_VERSION="0.43.0"                      # Kafka operator for Flink StateFun (v1beta2)
KAFKA_NS=default                              # ns for the StateFun Kafka cluster + topics

# ── Flink StateFun custom images (streaming baseline) ────────────────────────
# Built by the streaming benchmark (docker). On a multi-node cluster every node's
# containerd needs them, so 07-load-images.sh imports the tarballs below into each
# node (export them once on node 0 with: docker save <img> -o <dir>/<img>.tar).
STATEFUN_IMAGES="streaming-example-statefun streaming-example-mediareview streaming-example-socialnetwork"
IMAGE_TARBALL_DIR="/opt/myapp/WebAsShared/Tests/Inter-Node deployment/k8s/images"

# ── shared state (baselines' KV) ─────────────────────────────────────────────
# Cloudburst (Anna→Redis) and RMMap (ES protocol) both point REDIS_HOST here.
# Currently set to NODE 0 (this box) for testing. NOTE: a default Redis runs in
# PROTECTED MODE (loopback-only) — workers can't reach 10.10.1.2:6379 until you
# bind + open it on node 0:
#     redis-cli config set protected-mode no
#     redis-cli config set bind "0.0.0.0"        # or 10.10.1.2; then CONFIG REWRITE
# (For the headline runs the plan prefers a DEDICATED 5th box off the compute path
# — fairness §8 — or ./05-redis.sh for an in-cluster Redis at <node>:30679.)
REDIS_HOST=10.10.1.2
REDIS_PORT=6379

# k3s writes the admin kubeconfig here on the server node.
KUBECONFIG_PATH=/etc/rancher/k3s/k3s.yaml
