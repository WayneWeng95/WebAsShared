# RTSFaaS cluster topology — single source of truth, git-synced to every node.
# run-role.sh on each node reads this and derives an IDENTICAL RTSFaaS Cluster.env,
# so the roles rendezvous over RDMA without any coordinator/ssh. Edit once, sync.
#
# COORD_IP  = the node that runs database + driver + client (the coordinator box).
# WORKER_IPS = space-separated worker node IPs (one `worker` role launches per IP).
# APP       = MediaReview | SocialNetwork
COORD_IP=10.10.1.2
WORKER_IPS="10.10.1.1"
APP=MediaReview
