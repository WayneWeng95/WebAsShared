{
  "_comment": "Mode 2 (per-round output RETURN) — Node 1 (worker). Run on 10.10.1.1.",
  "_comment2": "One StreamPipeline does BOTH halves per round: rdma_recv the decoded image",
  "_comment3": "from node 0 into stream slot 20, run the full 5-stage pipeline",
  "_comment4": "(rotate->grayscale->equalize->blur->export), then rdma_send the processed",
  "_comment5": "PGM (Io slot 5) back to node 0 each round (free_after double-buffers it).",
  "shm_path": "/dev/shm/xnode_m2_node1",
  "wasm_path": "Executor/target/wasm32-unknown-unknown/release/guest.wasm",
  "log_level": "info",
  "rdma": {
    "node_id": 1,
    "total": 2,
    "ips": ["10.10.1.2", "10.10.1.1"],
    "transfer": true
  },
  "nodes": [
    {
      "id": "pipe",
      "deps": [],
      "kind": { "StreamPipeline": {
        "rounds": 3,
        "stages": [
          { "func": "img_rotate",     "arg0": 20, "arg1": 30 },
          { "func": "img_grayscale",  "arg0": 30, "arg1": 40 },
          { "func": "img_equalize",   "arg0": 40, "arg1": 50 },
          { "func": "img_blur",       "arg0": 50, "arg1": 60 },
          { "func": "img_export_ppm", "arg0": 60, "arg1": 5  }
        ],
        "rdma_recv": { "peer": 0, "slot": 20, "slot_kind": "Stream" },
        "rdma_send": { "peer": 0, "slot": 5,  "slot_kind": "Io", "free_after": true }
      }}
    }
  ]
}
