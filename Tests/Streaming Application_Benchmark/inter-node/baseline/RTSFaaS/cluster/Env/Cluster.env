# RTSFaaS cluster topology (4-node, in-memory RDMA store — NO TiKV).
# Lifts single_node/Env/Cluster.env to the cluster. Hosts are the RoCE reverse-DNS
# names (driver matches a worker by workerHosts[i].equals(getHostName()) of the NIC
# IP — single-node fix #5). NOTE the non-sequential IP->name map on this cluster:
#   10.10.1.2 -> node-0-link-0   10.10.1.1 -> node-1-link-0
#   10.10.1.3 -> node-3-link-0   10.10.1.4 -> node-2-link-0
# workerId i runs on the node whose reverse-DNS == workerHosts[i]; the orchestration
# (cluster.env WORKER_IPS) MUST list IPs in the same workerId order.
gatewayHost=localhost
gatewayPort=5556
driverHost=node-0-link-0
driverPort=5559
workerNum=4
workerHosts=node-0-link-0,node-1-link-0,node-3-link-0,node-2-link-0
workerPorts=5550,5540,5530,5520
