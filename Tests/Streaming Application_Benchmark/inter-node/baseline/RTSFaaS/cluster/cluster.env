# RTSFaaS cluster ORCHESTRATION topology — single source of truth, identical on
# every node. This is the dedicated RTSFaaS deployment substrate (its own tiny
# per-node agent, NOT the faasm one): rt-agent.py launches RTSFaaS role containers
# on each node; rt-coordinator.py places driver/database/worker*N/client and reads
# the client's end-to-end throughput + latency. Replaces RTSFaaS's shipped
# scp+ssh run-application.sh.
#
# WORKER_IPS are in workerId order and MUST align with Env/Cluster.env workerHosts
# (workerId i runs on WORKER_IPS[i], whose reverse-DNS == workerHosts[i]).

COORD_IP=10.10.1.2                              # node 0: runs driver + database + client
WORKER_IPS="10.10.1.2 10.10.1.1 10.10.1.3 10.10.1.4"   # workerId 0..3 -> node-0/1/3/2-link-0
AGENT_PORT=9700                                 # rt-agent HTTP port (distinct from faasm 9600 / node-agent 9500)
IMAGE=rtfaas:1.0                                # built from compare_system/RTSFaaS/Dockerfile (+ the 7 single-node fixes)
REPO=/opt/myapp/WebAsShared                     # identical repo path on every node (matches NodeAgent executor_work_dir)
DOCKER="sudo docker"                            # privileged containers (RDMA/infiniband); needs passwordless sudo for docker
