FROM python:3.8-slim

RUN mkdir -p /app/protobuf
WORKDIR /app

COPY driver/requirements.txt /app
RUN python -m pip install --upgrade setuptools pip wheel
RUN pip install -r requirements.txt

COPY driver/stream_bench.py /app
COPY protobuf/messages_pb2.py /app/protobuf/

ENTRYPOINT ["python", "stream_bench.py"]
